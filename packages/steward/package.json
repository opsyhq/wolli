{
	"name": "@opsyhq/steward",
	"version": "0.0.1",
	"description": "Persistent, purposeful agent CLI with memory and identity",
	"type": "module",
	"piConfig": {
		"name": "steward",
		"configDir": ".steward"
	},
	"bin": {
		"steward": "dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/cli.js",
		"typecheck": "tsgo -p tsconfig.build.json --noEmit",
		"test": "vitest --run"
	},
	"dependencies": {
		"@opsyhq/agent": "workspace:*",
		"@opsyhq/tui": "workspace:*",
		"@earendil-works/pi-ai": "^0.79.3",
		"proper-lockfile": "4.1.2",
		"typebox": "1.1.38"
	},
	"devDependencies": {
		"@types/node": "24.12.4",
		"@types/proper-lockfile": "4.1.4",
		"shx": "0.4.0",
		"typescript": "5.9.3",
		"vitest": "3.2.4"
	},
	"keywords": [
		"agent",
		"ai",
		"llm",
		"cli",
		"tui",
		"memory"
	],
	"license": "MIT",
	"engines": {
		"node": ">=22.19.0"
	}
}
