{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"@opsyhq/agent": ["./packages/agent/src/index.ts"],
			"@opsyhq/agent/*": ["./packages/agent/src/*"],
			"@opsyhq/tui": ["./packages/tui/src/index.ts"],
			"@opsyhq/tui/*": ["./packages/tui/src/*"],
			"@opsyhq/coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@opsyhq/coding-agent/*": ["./packages/coding-agent/src/*"],
			"@opsyhq/steward": ["./packages/steward/src/index.ts"],
			"@opsyhq/steward/*": ["./packages/steward/src/*"]
		}
	},
	"include": ["packages/*/src/**/*.ts", "packages/*/test/**/*.ts"],
	"exclude": ["**/node_modules/**", "**/dist/**", "packages/coding-agent/examples/**"]
}
