{
	"$schema": "https://biomejs.dev/schemas/2.3.5/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useNodejsImportProtocol": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noControlCharactersInRegex": "off",
				"noEmptyInterface": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},
	"files": {
		"includes": [
			"packages/*/src/**/*.ts",
			"packages/*/test/**/*.ts",
			"packages/wolli/examples/**/*.ts",
			"apps/marketing/src/**/*.ts",
			"apps/marketing/src/**/*.tsx",
			"apps/marketing/vite.config.ts",
			"apps/docs/src/**/*.ts",
			"apps/docs/src/**/*.tsx",
			"apps/docs/vite.config.ts",
			"apps/docs/source.config.ts",
			"!packages/coding-agent",
			"!apps/marketing/src/routeTree.gen.ts",
			"!apps/docs/src/routeTree.gen.ts",
			"!**/node_modules/**/*",
			"!**/dist/**/*",
			"!**/*.generated.ts"
		]
	}
}
